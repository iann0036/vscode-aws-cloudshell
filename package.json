{
    "name": "aws-cloudshell",
    "displayName": "AWS CloudShell plugin for VS Code",
    "description": "Open AWS CloudShell terminals within VS Code.",
    "author": {
        "name": "Ian Mckay",
        "email": "vscodeext@ian.mn"
    },
    "version": "0.1.7",
    "publisher": "iann0036",
    "icon": "resources/logo_128.png",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "maintainers": [
        "Ian Mckay <vscodeext@ian.mn>"
    ],
    "contributors": [
        "Ian Mckay <vscodeext@ian.mn>"
    ],
    "activationEvents": [
        "onView:aws-cloudshell-view-1-sessions",
        "onCommand:awscloudshell.startSession",
        "onCommand:awscloudshell.refresh",
        "onCommand:awscloudshell.selectProfile",
        "onCommand:awscloudshell.configureVpc",
        "onCommand:awscloudshell.reapplyCredentials",
        "onCommand:awscloudshell.terminateSession",
        "onCommand:awscloudshell.openSession",
        "onCommand:awscloudshell.uploadFile"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/iann0036/vscode-aws-cloudshell.git"
    },
    "bugs": {
        "url": "https://github.com/iann0036/vscode-aws-cloudshell/issues"
    },
    "keywords": [
        "AWS",
        "CloudShell",
        "terminal",
        "collaboration"
    ],
    "galleryBanner": {
        "color": "#3c3c3c",
        "theme": "dark"
    },
    "main": "./out/extension",
    "contributes": {
        "menus": {
            "view/title": [
                {
                    "command": "awscloudshell.startSession",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "navigation@1"
                },
                {
                    "command": "awscloudshell.refresh",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "navigation@2"
                },
                {
                    "command": "awscloudshell.openSession",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "session@1"
                },
                {
                    "command": "awscloudshell.reapplyCredentials",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "session@2"
                },
                {
                    "command": "awscloudshell.terminateSession",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "session@3"
                },
                {
                    "command": "awscloudshell.selectProfile",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "config@1"
                },
                {
                    "command": "awscloudshell.configureVpc",
                    "when": "view == aws-cloudshell-view-1-sessions",
                    "group": "config@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "awscloudshell.openSession",
                    "when": "view == aws-cloudshell-view-1-sessions && (viewItem == connectedSession || viewItem == discoveredSession)",
                    "group": "inline"
                },
                {
                    "command": "awscloudshell.reapplyCredentials",
                    "when": "view == aws-cloudshell-view-1-sessions && viewItem == connectedSession",
                    "group": "inline"
                },
                {
                    "command": "awscloudshell.terminateSession",
                    "when": "view == aws-cloudshell-view-1-sessions && (viewItem == connectedSession || viewItem == discoveredSession)",
                    "group": "inline"
                },
                {
                    "command": "awscloudshell.openSession",
                    "when": "view == aws-cloudshell-view-1-sessions && (viewItem == connectedSession || viewItem == discoveredSession)",
                    "group": "session@1"
                },
                {
                    "command": "awscloudshell.reapplyCredentials",
                    "when": "view == aws-cloudshell-view-1-sessions && viewItem == connectedSession",
                    "group": "session@2"
                },
                {
                    "command": "awscloudshell.terminateSession",
                    "when": "view == aws-cloudshell-view-1-sessions && (viewItem == connectedSession || viewItem == discoveredSession)",
                    "group": "session@3"
                }
            ],
            "explorer/context": [
                {
                    "command": "awscloudshell.uploadFile",
                    "when": "resourceScheme == file && config.awscloudshell.enableUpload == true"
                }
            ]
        },
        "commands": [
            {
                "command": "awscloudshell.startSession",
                "title": "Start Session",
                "category": "AWS CloudShell",
                "icon": {
                    "light": "resources/icons/new-light.png",
                    "dark": "resources/icons/new-dark.png"
                }
            },
            {
                "command": "awscloudshell.refresh",
                "title": "Refresh Sessions",
                "category": "AWS CloudShell",
                "icon": "$(refresh)"
            },
            {
                "command": "awscloudshell.selectProfile",
                "title": "Select AWS Profile",
                "category": "AWS CloudShell",
                "icon": "$(account)"
            },
            {
                "command": "awscloudshell.configureVpc",
                "title": "Configure VPC…",
                "category": "AWS CloudShell",
                "icon": "$(globe)"
            },
            {
                "command": "awscloudshell.reapplyCredentials",
                "title": "Re-apply Credentials to Shell",
                "category": "AWS CloudShell",
                "icon": "$(key)"
            },
            {
                "command": "awscloudshell.openSession",
                "title": "Open Session…",
                "category": "AWS CloudShell",
                "icon": "$(terminal)"
            },
            {
                "command": "awscloudshell.terminateSession",
                "title": "Terminate Session…",
                "category": "AWS CloudShell",
                "icon": "$(close)"
            },
            {
                "command": "awscloudshell.uploadFile",
                "title": "Upload file to AWS CloudShell",
                "category": "AWS CloudShell"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "aws-cloudshell-vc",
                    "title": "AWS CloudShell",
                    "icon": "resources/sidebar.png"
                }
            ]
        },
        "views": {
            "aws-cloudshell-vc": [
                {
                    "id": "aws-cloudshell-view-1-sessions",
                    "name": "Sessions"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "AWS CloudShell Configuration",
            "properties": {
                "awscloudshell.region": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "The AWS region for CloudShell. Leave empty to use the selected profile's region (falling back to `AWS_REGION`, then `us-east-1`)."
                },
                "awscloudshell.profile": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "The profile to use for an INI credential provider. Tip: run **AWS CloudShell: Select AWS Profile** to pick from your configured profiles."
                },
                "awscloudshell.assumeRole": {
                    "type": "string",
                    "default": "",
                    "description": "The ARN of a role to assume into."
                },
                "awscloudshell.enableUpload": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable upload file menu option from Explorer view."
                },
                "awscloudshell.injectCredentials": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Automatically inject your (temporary) AWS credentials into the shell as environment variables when connecting to a non-VPC environment. Disabled by default. When off, use the **Re-apply Credentials to Shell** command to inject them on demand."
                },
                "awscloudshell.vpcid": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "The VPC Id to attach this environment to. Tip: run **AWS CloudShell: Configure VPC…** to pick a VPC, subnet, and security group interactively."
                },
                "awscloudshell.subnetid": {
                    "type": "string",
                    "default": "",
                    "description": "The Subnet Id to attach this environment to."
                },
                "awscloudshell.securitygroupid": {
                    "type": "string",
                    "default": "",
                    "description": "The Security Group Id to attach this environment to."
                },
                "awscloudshell.vpcRegion": {
                    "type": "string",
                    "default": "",
                    "description": "Internal: the region the saved VPC settings were configured for. Managed by the Configure VPC… command."
                },
                "awscloudshell.vpcProfile": {
                    "type": "string",
                    "default": "",
                    "description": "Internal: the profile the saved VPC settings were configured for. Managed by the Configure VPC… command."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "lint": "eslint . --ext .ts,.tsx",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "mocha"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.75.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0",
        "mocha": "^10.2.0",
        "typescript": "^5.4.0"
    },
    "dependencies": {
        "@aws-sdk/client-ec2": "^3.1072.0",
        "@aws-sdk/client-sts": "^3.1072.0",
        "@aws-sdk/credential-provider-node": "^3.972.57",
        "@aws-sdk/credential-provider-process": "^3.972.48",
        "@smithy/shared-ini-file-loader": "^4.6.1",
        "aws4": "^1.11.0",
        "axios": "^0.21.0",
        "axios-cookiejar-support": "^1.0.1",
        "form-data": "^3.0.0",
        "tough-cookie": "^4.0.0",
        "utf-8-validate": "^5.0.3",
        "xml2js": "^0.4.23"
    }
}
