{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2019,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "env": {
        "node": true,
        "es2019": true
    },
    "rules": {
        "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "semi": ["warn", "always"],
        "no-throw-literal": "warn",
        "eqeqeq": "off"
    },
    "ignorePatterns": [
        "out",
        "node_modules",
        "**/*.d.ts"
    ]
}
